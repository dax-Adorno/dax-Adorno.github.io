---
import "../styles/global.css";

const projects = [
  {
    title: "AI Risk Decision Demo",
    desc: "Demo de sistema de apoyo a decisiones basado en IA para evaluación de riesgo crediticio.",
    repo: "https://github.com/dax-Adorno/ai-risk-decision-demo",
    media: "/gifs/ai-risk.png",
    stack: ["Python", "Machine Learning", "Data Analysis"],
  },
  {
    title: "Zoonosis System",
    desc: "Sistema web de gestión con React + TypeScript.",
    repo: "https://github.com/dax-Adorno/zoonosis",
    media: "/gifs/zoonosis.gif",
    stack: ["React", "TypeScript", "Vite"],
  },
  {
    title: "Python ETL Reporter",
    desc: "Automatización de reportes desde Excel hacia documentos Word incorporando vista Open Street Map.",
    repo: "https://github.com/dax-Adorno/python-etl-reporter",
    media: "/gifs/etl-reporter.gif",
    stack: ["Python", "Pandas", "ETL"],
  },
  {
    title: "Kotlin Mobile Demo",
    desc: "Calculadora impositiva, creada con Android desarrollada con Kotlin y Jetpack Compose.",
    repo: "https://github.com/dax-Adorno/kotlin-mobile-demo",
    media: "/gifs/kotlin-mobile.gif",
    stack: ["Kotlin", "Compose", "Android"],
  },
];

const links = {
  github: "https://github.com/dax-Adorno",
  linkedin: "https://www.linkedin.com/in/eduardo-dax-adorno-b-09a7072a2",
  cv: "/Eduardo_Dax_Adorno_FullStack_Developer.pdf",
};
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dax Adorno | Portfolio</title>
  </head>

  <body class="bg-slate-950 text-white">
    <div class="max-w-6xl mx-auto px-6 py-16">
		<nav class="sticky top-4 z-50 mb-8">
  <div class="mx-auto flex max-w-fit items-center gap-2 rounded-2xl border border-slate-800/80 bg-slate-950/70 px-3 py-3 shadow-[0_10px_40px_rgba(0,0,0,0.45)] backdrop-blur-xl">
    
    <a
