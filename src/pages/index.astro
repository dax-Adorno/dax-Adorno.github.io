      <section id="projects">
        <div class="mb-8">
     <h2 class="text-3xl font-bold text-white">Featured Projects</h2>
     <p class="mt-2 text-slate-400">
      Selección de proyectos con foco en producto, arquitectura y experiencia técnica.
     </p>
	 </div>

        <div class="grid md:grid-cols-2 gap-6">
          {projects.map((p) => (
            <article
              class="group relative overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60 backdrop-blur
                     transition-all duration-300 hover:-translate-y-1 hover:border-blue-400/60
                     hover:shadow-[0_0_0_1px_rgba(96,165,250,.2),0_20px_60px_-20px_rgba(0,0,0,.8)]"
            >
              {/* glow */}
              <div
                class="pointer-events-none absolute -inset-24 opacity-0 blur-3xl transition-opacity duration-300 group-hover:opacity-100"
                style="background: radial-gradient(circle at 30% 20%, rgba(59,130,246,.35), transparent 60%);"
              />

              {/* media */}
              <div class="relative">
                <img
                  src={p.media}
                  alt={p.title}
                  loading="lazy"
                  class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                />
                <div class="absolute inset-0 bg-linear-to-t from-slate-950/70 via-slate-950/10 to-transparent" />
              </div>

              <div class="p-6">
                <h3 class="text-lg font-semibold">{p.title}</h3>

                <p class="text-slate-400 mt-2">{p.desc}</p>

                <div class="mt-4 flex flex-wrap gap-2">
                  {p.stack.map((tech) => (
                    <span class="rounded-full border border-slate-700/80 bg-slate-950/40 px-3 py-1 text-xs text-slate-200">
                      {tech}
                    </span>
                  ))}
                </div>

                <div class="mt-6 flex flex-wrap gap-3">
                  <a
                    href={p.repo}
                    target="_blank"
                    class="rounded-lg bg-blue-500 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-400 transition"
                  >
                    Ver repo →
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    </div>
  </body>
</html>